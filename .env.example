# ── Public URL of THIS connector (the Linode box, behind TLS) ──────────────
# Used to advertise the resource identifier in Protected Resource Metadata.
CONNECTOR_BASE_URL=https://connector.ipromo.com
PORT=8080

# ── Stytch (the OAuth authorization server that verifies identity) ─────────
# From Stytch dashboard → API Keys. Start with the Test env, switch to Live later.
STYTCH_PROJECT_ID=project-test-xxxxxxxx
STYTCH_SECRET=secret-test-xxxxxxxx
# Your project's auth-server domain, e.g. https://xxxx.stytch.dev (test) or your live domain.
# This is what Claude is pointed at for login; the connector only validates tokens from it.
STYTCH_AUTHORIZATION_SERVER=https://xxxx.stytch.dev

# ── SendGrid ───────────────────────────────────────────────────────────────
# Restricted key — "Mail Send" scope ONLY. Never exposed to users.
SENDGRID_API_KEY=SG.xxxxxxxx

# ── Guardrails ──────────────────────────────────────────────────────────────
PER_USER_DAILY_CAP=200
GLOBAL_DAILY_CAP=2000
# Only allow sending as addresses on these domains (defense in depth vs. token surprises)
ALLOWED_SENDER_DOMAINS=ipromo.com
